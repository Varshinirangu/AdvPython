a=input("ENTER A PASSWORD:")
up=0
sm=0
dg=0
sp=0
if len(a)>7:
  for i in a:
    if i.isupper():
      up=up+1
    elif i.islower():
      sm=sm+1
    elif i.isdigit():
      dg=dg+1
    else:
      sp=sp+1
  if up>0 and sm>0 and sp>0 and dg>0:
    print("STRONG PASS")
  else:
    print("WEAK PASS")
else:
  print("WEAK PASS DUE TO LESS NO.OF CHARA")
